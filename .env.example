# Copy this file to ".env" and fill in your key to turn on the optional Claude
# reasoning layer (plain-language explanations of findings + mapping
# suggestions). The app runs fully offline without this — the local learning
# memory works either way.
#
#   cp .env.example .env      # then edit .env and paste your key
#
# The .env file is git-ignored and docker-ignored, so your key never lands in
# a commit or a built image.

# Your Anthropic API key (https://console.anthropic.com/). Leave blank to stay offline.
ANTHROPIC_API_KEY=

# Optional: override the model used for explanations/suggestions.
# MIGRATION_LLM_MODEL=claude-sonnet-5
